{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "DATABASE_NAME",
        "MONGODB_URI",
        "EMAIL_USER",
        "APP_PASSWORD",
        "GEMINI_API_KEY",
        "NEXTAUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "SALT_ROUNDS",
        "NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT",
        "NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY",
        "IMAGEKIT_PRIVATE_KEY",
        "GITHUB_SECRET_TOKEN",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_LOGO_DEV_KEY",
        "ROLE",
        "PRIVATE_KEY_LENGTH",
        "DODO_PAYMENTS_API_KEY",
        "DODO_WEBHOOK_SECRET",
        "DODO_PAYMENTS_ENVIRONMENT",
        "DODO_PAYMENTS_RETURN_URL",
        "PRODUCT_PRO_50_CREDITS"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "env": [
        "NODE_ENV",
        "DATABASE_NAME",
        "MONGODB_URI",
        "EMAIL_USER",
        "APP_PASSWORD",
        "GEMINI_API_KEY",
        "NEXTAUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "SALT_ROUNDS",
        "NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT",
        "NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY",
        "IMAGEKIT_PRIVATE_KEY",
        "GITHUB_SECRET_TOKEN",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_LOGO_DEV_KEY",
        "ROLE",
        "PRIVATE_KEY_LENGTH",
        "DODO_PAYMENTS_API_KEY",
        "DODO_WEBHOOK_SECRET",
        "DODO_PAYMENTS_ENVIRONMENT",
        "DODO_PAYMENTS_RETURN_URL",
        "PRODUCT_PRO_50_CREDITS"
      ],
      "cache": false,
      "persistent": true
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    }
  }
}
