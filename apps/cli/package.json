{
  "name": "devkit-tool-cli",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "devkit": "./bin/devkit.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
