{
  "name": "@devkit/cli",
  "version": "1.0.0",
  "module": "index.ts",
  "description": "It's a CLI for Devkit which helps you to setup reusable production code.",
  "keywords": [
    "module",
    "production-code",
    "boilerplate",
    "devkit"
  ],
  "license": "MIT",
  "author": "Devkit",
  "type": "module",
  "private": true,
  "bin": {
    "devkit": "bin/devkit.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cli-progress": "^3.11.6",
    "@types/prompts": "^2.4.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "axios": "^1.15.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "figlet": "^1.11.0",
    "ora": "^9.3.0",
    "prompts": "^2.4.2"
  }
}
